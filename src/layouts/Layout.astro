---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Encantia Studios - Desarrollo web y experiencias gaming" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="navbar-header">
			<div class="navbar-container">
				
				<a href="/" class="logo">
					ENCANTIA <span class="logo-accent">STUDIOS</span>
				</a>

				<div class="nav-center-capsule">
					<nav class="nav-links">
						<a href="/" class="nav-item">Inicio</a>
						<a href="/proyectos" class="nav-item">Proyectos</a>
						<a href="/contacto" class="nav-item">Contacto</a>
						
						<button class="menu-toggle" id="menu-toggle-btn" aria-label="Abrir más secciones">
							<span class="bar"></span>
							<span class="bar"></span>
							<span class="bar"></span>
						</button>
					</nav>

					<div class="dropdown-menu" id="dropdown-menu-container">
						<span class="dropdown-title">MÁS SECCIONES</span>
						<div class="dropdown-links">
							<a href="/roles" class="dropdown-link">
								<span class="link-icon">🛡️</span> Roles de Discord
							</a>
							<a href="/unirse" class="dropdown-link highlight-link">
								<span class="link-icon">📄</span> <span class="pulse-dot">●</span> Postulaciones
							</a>
						</div>
					</div>
				</div>

				<div class="navbar-right">
					<a href="https://discord.gg/Rx6Hjf5Pks" target="_blank" class="discord-btn">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" class="discord-logo">
							<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.1 18.099a.082.082 0 0 0 .031.058 19.95 19.95 0 0 0 6.007 2.794.077.077 0 0 0 .085-.027c.461-.63.882-1.295 1.277-2a.076.076 0 0 0-.041-.106 12.68 12.68 0 0 1-1.838-.89.078.078 0 0 1-.008-.13c.12-.089.241-.182.358-.277a.077.077 0 0 1 .082-.01c3.567 1.625 7.427 1.625 10.932 0a.077.077 0 0 1 .08.006c.118.094.24.187.359.277a.077.077 0 0 1-.008.13 12.65 12.65 0 0 1-1.838.89.077.077 0 0 0-.041.106c.395.705.816 1.37 1.277 2a.077.077 0 0 0 .085.027 19.98 19.98 0 0 0 6.007-2.794.077.077 0 0 0 .031-.058c.477-4.61-.358-9.145-3.327-13.702a.07.07 0 0 0-.032-.027zM8.02 15.332c-1.18 0-2.155-1.085-2.155-2.419 0-1.333.955-2.419 2.155-2.419 1.21 0 2.176 1.096 2.155 2.419 0 1.333-.955 2.419-2.155 2.419zm7.974 0c-1.18 0-2.155-1.085-2.155-2.419 0-1.333.955-2.419 2.155-2.419 1.21 0 2.176 1.096 2.155 2.419 0 1.333-.946 2.419-2.155 2.419z"/>
						</svg>
						<span>Únete a la comunidad</span>
					</a>
				</div>

			</div>
		</header>

		<main class="content-wrapper">
			<slot />
		</main>

		<footer class="main-footer">
			<div class="footer-container">
				<div class="footer-column branding">
					<h2 class="footer-logo">ENCANTIA<span class="dot">.</span></h2>
					<p class="footer-desc">
						Dedicados a la creación de landing pages de alto impacto, organización de eventos inmersivos en Minecraft y Roblox.
					</p>
				</div>

				<div class="footer-column links">
					<h3>NAVEGACIÓN</h3>
					<ul>
						<li><a href="/">Inicio</a></li>
						<li><a href="/proyectos">Proyectos de Éxito</a></li>
						<li><a href="/unirse">Unirse al Equipo</a></li>
					</ul>
				</div>

				<div class="footer-column links">
					<h3>COMUNIDAD & REDES</h3>
					<ul>
						<li><a href="https://instagram.com/encantia.studios" target="_blank">Instagram ↗</a></li>
						<li><a href="https://discord.gg/Rx6Hjf5Pks" target="_blank">Discord ↗</a></li>
					</ul>
				</div>
			</div>

			<div class="footer-bottom">
				<p>
					<a href="https://encantia.xyz/">Encantia Studios</a> © 2026 by <a href="https://example.com">Encantia Studios</a> is licensed under <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/" target="_blank" rel="license noopener noreferrer">CC BY-NC-ND 4.0</a>
					<img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" alt="CC" class="cc-icon">
					<img src="https://mirrors.creativecommons.org/presskit/icons/by.svg" alt="BY" class="cc-icon">
					<img src="https://mirrors.creativecommons.org/presskit/icons/nc.svg" alt="NC" class="cc-icon">
					<img src="https://mirrors.creativecommons.org/presskit/icons/nd.svg" alt="ND" class="cc-icon">
				</p>
			</div>
		</footer>

		<script>
			const toggleBtn = document.getElementById('menu-toggle-btn');
			const dropdownMenu = document.getElementById('dropdown-menu-container');

			toggleBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				toggleBtn.classList.toggle('active');
				dropdownMenu?.classList.toggle('active');
			});

			// Cierra el menú si se hace clic fuera de él
			document.addEventListener('click', () => {
				toggleBtn?.classList.remove('active');
				dropdownMenu?.classList.remove('active');
			});
		</script>
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Mea+Culpa&display=swap');

	:root {
		--bg-dark: #030303;
		--text-main: #ffffff;
		--text-muted: #94a3b8;
		--purple-primary: #a855f7;
		--purple-bright: #c084fc;
	}

	* { box-sizing: border-box; margin: 0; padding: 0; }

	body {
		background-color: var(--bg-dark);
		color: var(--text-main);
		font-family: 'Inter', system-ui, sans-serif;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		overflow-x: hidden;
	}

	.content-wrapper { flex: 1; }

	/* --- NAVBAR CONTENEDOR --- */
	.navbar-header {
		width: 100%;
		background: rgba(3, 3, 3, 0.75);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.navbar-container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 20px 32px;
		display: grid;
		grid-template-columns: 1fr auto 1fr; /* Fuerza el centro perfecto */
		align-items: center;
	}

	.logo {
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 2px;
		color: #ffffff;
		text-decoration: none;
		justify-self: start;
	}

	.logo-accent { color: var(--purple-primary); }

	/* --- CÁPSULA CENTRAL --- */
	.nav-center-capsule {
		position: relative;
		justify-self: center;
	}

	.nav-links {
		display: flex;
		align-items: center;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 99px;
		padding: 4px 6px 4px 16px;
		gap: 4px;
	}

	.nav-item {
		color: var(--text-muted);
		font-size: 13px;
		font-weight: 500;
		text-decoration: none;
		padding: 8px 14px;
		transition: color 0.2s;
	}

	.nav-item:hover { color: #ffffff; }

	/* --- BOTÓN HAMBURGUESA INTERNO (☰) --- */
	.menu-toggle {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		width: 16px;
		height: 12px;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0;
		margin-left: 10px;
		margin-right: 12px;
	}

	.menu-toggle .bar {
		width: 100%;
		height: 2px;
		background-color: var(--text-muted);
		border-radius: 2px;
		transition: all 0.2s ease;
	}

	.menu-toggle:hover .bar { background-color: #ffffff; }

	.menu-toggle.active .bar:nth-child(1) { transform: translateY(5px) rotate(45deg); background-color: #ffffff; }
	.menu-toggle.active .bar:nth-child(2) { opacity: 0; }
	.menu-toggle.active .bar:nth-child(3) { transform: translateY(-5px) rotate(-45deg); background-color: #ffffff; }

	/* --- DESPLEGABLE DESDE EL CENTRO --- */
	.dropdown-menu {
		position: absolute;
		top: 120%;
		left: 50%;
		transform: translateX(-50%) translateY(-10px);
		background: #0b0b12;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 16px;
		min-width: 220px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7);
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s ease, transform 0.25s ease;
		z-index: 120;
	}

	.dropdown-menu.active {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
		pointer-events: auto;
	}

	.dropdown-title {
		font-size: 9px;
		font-weight: 700;
		color: #475569;
		letter-spacing: 0.12em;
	}

	.dropdown-links { display: flex; flex-direction: column; gap: 4px; }

	.dropdown-link {
		color: var(--text-muted);
		font-size: 13.5px;
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 8px 10px;
		border-radius: 8px;
		transition: background 0.2s, color 0.2s;
	}

	.dropdown-link:hover {
		color: #ffffff;
		background: rgba(255, 255, 255, 0.03);
	}

	.highlight-link { color: #ffffff; }
	.link-icon { font-size: 14px; }

	.pulse-dot {
		color: var(--purple-primary);
		font-size: 8px;
		animation: pulseKeyframe 2s infinite;
	}

	@keyframes pulseKeyframe {
		0%, 100% { opacity: 0.4; }
		50% { opacity: 1; }
	}

	/* --- BOTÓN DISCORD DERECHA --- */
	.navbar-right { justify-self: end; }

	.discord-btn {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: #ffffff;
		font-size: 12.5px;
		font-weight: 500;
		text-decoration: none;
		padding: 10px 18px;
		border-radius: 99px;
		display: flex;
		align-items: center;
		gap: 8px;
		transition: border 0.2s, background 0.2s;
	}

	.discord-btn:hover {
		background: rgba(168, 85, 247, 0.08);
		border: 1px solid rgba(168, 85, 247, 0.3);
	}

	/* --- FOOTER STYLES --- */
	.main-footer {
		border-top: 1px solid rgba(255, 255, 255, 0.03);
		background-color: #020202;
		padding: 60px 24px 30px 24px;
	}
	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 60px;
	}
	.footer-logo { font-size: 20px; font-weight: 700; margin-bottom: 14px; }
	.footer-logo .dot { color: var(--purple-primary); }
	.footer-desc { color: #64748b; font-size: 13.5px; line-height: 1.6; }
	.footer-column h3 { font-size: 11px; color: #cbd5e1; letter-spacing: 0.1em; margin-bottom: 18px; }
	.footer-column ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
	.footer-column ul a { color: #64748b; font-size: 13.5px; text-decoration: none; transition: color 0.3s; }
	.footer-column ul a:hover { color: #ffffff; }
	.footer-highlight { color: var(--purple-primary) !important; }
	
	.footer-bottom { 
		max-width: 1200px; 
		margin: 40px auto 0 auto; 
		padding-top: 20px; 
		border-top: 1px solid rgba(255, 255, 255, 0.02); 
	}
	.footer-bottom p { 
		font-size: 12px; 
		color: #475569; 
		line-height: 1.8;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 2px;
	}
	.footer-bottom a {
		color: #64748b;
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-bottom a:hover {
		color: #ffffff;
	}
	
	/* Estilos para los iconos de Creative Commons */
	.cc-icon {
		max-width: 1em;
		max-height: 1em;
		margin-left: .2em;
		vertical-align: middle;
		filter: opacity(0.5) invert(1); /* Hace que los iconos se adapten al modo oscuro */
		transition: filter 0.2s;
	}
	.footer-bottom p:hover .cc-icon {
		filter: opacity(0.8) invert(1);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.navbar-container {
			grid-template-columns: 1fr auto;
			gap: 16px;
		}
		.navbar-right { display: none; } /* Oculta discord en móviles muy pequeños */
	}
	@media (max-width: 768px) {
		.footer-container { grid-template-columns: 1fr; gap: 40px; }
	}
</style>
